# ========================================
# 2ndSTREET.html - Git Ignore File
# ========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# IDE & Editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Build outputs (如果未來有建置流程)
dist/
build/
out/

# Dependencies (如果未來使用 npm)
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# Test coverage (如果未來加入測試)
coverage/
.nyc_output/

# Backup files
*.backup
*.old

# Compressed files
*.zip
*.tar.gz
*.rar

# Local development
.vscode-test/
.test/
.local/

# Custom
# 在這裡新增專案特定的忽略檔案
